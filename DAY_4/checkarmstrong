// program to check a number is armstrong or not
//step 1 take the number to be checked from the user
// step 2 initialize a variable to store the sum of cubes of digits and a variable to store the original number
// step 3 use a while loop to extract each digit of the number and calculate the cube of the digit and add it to the sum variable
// step 4 after the loop, compare the sum with the original number and print the result
#include <iostream>
using namespace std;
int main() {
    int num, originalNum, remainder, result = 0;
    cout << "Enter an integer: ";
    cin >> num;
    originalNum = num;
    while (originalNum != 0) {
        remainder = originalNum % 10; // extract the last digit
        result += remainder * remainder * remainder; // add the cube of the digit to the result initially the rem is 0
        originalNum /= 10; // remove the last digit
    }
    if (result == num)
        cout << num << " is an Armstrong number.";
    else
        cout << num << " is not an Armstrong number.";
}
//output
//Enter an integer: 153
//153 is an Armstrong number.

